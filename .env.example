# Jano configuration. Copy to .env and adjust as needed.
# Only SWAP_COMMAND is strictly required.

# Where jano listens. Use 0.0.0.0 to expose over a private network (LAN /
# tailnet); use 127.0.0.1 for loopback-only.
JANO_HOST=127.0.0.1
JANO_PORT=8082

# REQUIRED. Path to a script that loads a model. It is invoked as:
#
#     <SWAP_COMMAND> <model-name>
#
# where <model-name> matches one of the names declared in MODELS_FILE. The
# script must be idempotent (calling it for the already-loaded model is a
# no-op) and exit 0 once the swap has been initiated. Jano then polls the
# matching backend's /health until it responds 200 or SWAP_WAIT_TIMEOUT_MS
# elapses.
#
# Optional: implementing a `<SWAP_COMMAND> status` subcommand that prints
# lines like "<model-name>: loaded" lets jano skip an unnecessary swap on
# startup by detecting the already-loaded model.
SWAP_COMMAND=/path/to/your-swap-script

# Path to the JSON file that declares the available backends.
# See models.example.json for the schema.
MODELS_FILE=./models.json

# How long jano waits for a backend to become healthy after a swap.
SWAP_WAIT_TIMEOUT_MS=180000
HEALTH_POLL_INTERVAL_MS=1000

# How long upstream chat-completions calls may take. Generous default for
# slow CPU / cold-cache generations on local models.
REQUEST_TIMEOUT_MS=600000

# How many recent request records jano keeps in memory for `GET /usage`
# (the "what did my last N requests cost" log). Older records drop FIFO.
# Purely observability; bump it for a longer benchmark history.
USAGE_RECORDS_MAX=500
